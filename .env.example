# ── WalletConnect (RainbowKit) ──
# Free project id from https://cloud.reown.com (formerly WalletConnect Cloud).
# A working fallback is baked in, but use your own for production.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=f0e5578180851413284be061ff7c7b8f

# ── Claim store backend ──
# Optional. When set, signed claim payloads are stored in Upstash Redis (works
# on Vercel). When unset, a local JSON file (.data/cloakdrop-store.json) is used
# for development. Create a free database at https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
